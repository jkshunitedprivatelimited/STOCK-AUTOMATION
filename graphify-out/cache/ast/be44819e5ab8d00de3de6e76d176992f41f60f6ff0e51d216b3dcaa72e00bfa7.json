caller_nid": "central_central_invoices_centralinvoices", "callee": "useState", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L244"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "useState", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L246"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "useEffect", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L248"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "useEffect", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L280"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "useMemo", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L459"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "useMemo", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L507"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "(() => {\n                    const fullItems = items || [];\n                    const pages = [];\n                    if (fullItems.length === 0) pages.push([]);\n                    else {\n                        for (let i = 0; i < fullItems.length; i += ITEMS_PER_INVOICE_PAGE) {\n                            pages.push(fullItems.slice(i, i + ITEMS_PER_INVOICE_PAGE));\n                        }\n                    }\n                    return pages.map((chunk, index) => (\n                        <FullPageInvoice\n                            key={index}\n                            order={selectedInvoice}\n                            companyDetails={companyDetails}\n                            pageIndex={index}\n                            totalPages={pages.length}\n                            itemsChunk={chunk}\n                        />\n                    ));\n                })", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L539"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "getStatusStyle", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L609"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "formatDateTime", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L610"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "map", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L622"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "(() => {\n                                    let totalSub = 0, totalGst = 0;\n                                    items.forEach(item => {\n                                        const rate = Number(item.price) || 0;\n                                        const qty = Number(item.quantity) || 0;\n                                        const basePrice = rate * qty;\n                                        const gstRate = Number(item.gst_rate) || 0;\n                                        const taxAmount = basePrice * (gstRate / 100);\n                                        totalSub += basePrice;\n                                        totalGst += taxAmount;\n                                    });\n                                    const transportationCharge = Number(selectedInvoice.transportation_charge) || 0;\n                                    const exactBill = parseFloat((totalSub + totalGst + transportationCharge).toFixed(2));\n                                    const roundedBill = Math.ceil(exactBill);\n                                    const roundOff = roundedBill - exactBill;\n                                    \n                                    return (\n                                        <div className=\"space-y-3\">\n                                            <div className=\"flex justify-between text-xs font-bold text-slate-500 uppercase tracking-widest\">\n                                                <span>Subtotal</span>\n                                                <span>\u20b9{totalSub.toFixed(2)}</span>\n                                            </div>\n                                            <div className=\"flex justify-between text-xs font-bold text-slate-500 uppercase tracking-widest\">\n                                                <span>Total GST</span>\n                                                <span>\u20b9{totalGst.toFixed(2)}</span>\n                                            </div>\n                                                <div className=\"flex justify-between text-xs font-bold text-slate-500 uppercase tracking-widest\">\n                                                    <span>Transportation</span>\n                                                    <span>\u20b9{transportationCharge.toFixed(2)}</span>\n                                                </div>\n                                            <div className=\"flex justify-between text-xs font-bold text-slate-500 uppercase tracking-widest border-b border-slate-100 pb-3\">\n                                                <span>Round Off</span>\n                                                <span>\u20b9{roundOff.toFixed(2)}</span>\n                                            </div>\n                                            <div className=\"flex justify-between items-center bg-slate-900 text-white p-5 rounded-2xl shadow-lg mt-3\">\n                                                <span className=\"text-xs font-black uppercase tracking-widest text-slate-400\">Total Payable</span>\n                                                <span className=\"text-2xl font-black\">\u20b9{roundedBill.toLocaleString('en-IN')}</span>\n                                            </div>\n                                        </div>\n                                    );\n                                })", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L650"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "toLocaleString", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L723"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "map", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L741"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "map", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L750"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "map", "source_file": "/Users/surojuhomsaisantosh/Desktop/SANTOSH/PROJECTS/5 JKSH/stock-automation/src/pages/central/central_invoices.jsx", "source_location": "L812"}, {"caller_nid": "central_central_invoices_centralinvoices", "callee": "map", "source_file": "/Users/sur